# Copy to .env and fill in. Both are optional:
# - Without GROQ_API_KEY, the tool uses a deterministic fallback miner.
# - Without API_BASE_URL, it uses the sanitized fixture (omit --live).

# Groq API key for LLM-based oracle mining (https://console.groq.com/keys)
GROQ_API_KEY=

# Base URL of the API to validate against (only needed for --live runs)
API_BASE_URL=
